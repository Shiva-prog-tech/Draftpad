# ─────────────────────────────────────────────────────────────────
# Draftpad — environment variables template
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.
# ─────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Get yours at: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Draftpad

# NextAuth v5
# Generate a secret:  openssl rand -base64 32
AUTH_SECRET=your-random-secret-min-32-characters
NEXTAUTH_SECRET=your-random-secret-min-32-characters
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Groq AI — free tier at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Email — SMTP for invite emails
# Gmail: myaccount.google.com → Security → 2-Step Verification → App passwords
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=you@gmail.com
EMAIL_SERVER_PASSWORD=your-16-char-app-password
EMAIL_FROM=Draftpad <you@gmail.com>

# Public app URL (used in invite email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Code Runner — uses the free public Wandbox API by default (NO API key needed).
# Only set this if you self-host Wandbox: https://github.com/melpon/wandbox
# WANDBOX_URL=https://wandbox.org
