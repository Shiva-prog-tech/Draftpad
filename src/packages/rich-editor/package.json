{
  "name": "@draftpad/rich-editor",
  "version": "1.0.1",
  "description": "Portable rich-text editor — toolbar, find/replace, hyperlinks, color, formatting",
  "keywords": [
    "rich-text",
    "editor",
    "react",
    "contenteditable",
    "toolbar"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "scripts": {
    "build": "tsup && node -e \"require('fs').copyFileSync('styles.css','dist/styles.css')\"",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "lucide-react": ">=0.300.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
